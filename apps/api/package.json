{
  "name": "@clinicos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "seed:demo": "tsx --env-file-if-exists=../../.env src/scripts/seed-demo.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server.mjs --packages=external",
    "start": "node --env-file-if-exists=../../.env dist/server.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clinicos/config": "*",
    "@clinicos/types": "*",
    "@clinicos/validation": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.4",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.2",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/pdfkit": "^0.13.8",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.28.1",
    "mongodb-memory-server": "^10.1.3",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
