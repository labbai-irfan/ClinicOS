{
  "name": "@clinicos/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.mjs --packages=external",
    "start": "node --env-file-if-exists=../../.env dist/index.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clinicos/types": "*",
    "bullmq": "^5.34.4",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.3",
    "pino": "^9.6.0",
    "twilio": "^5.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
