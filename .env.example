# ---- API (apps/api) ----
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:5173,http://localhost:5174

# MongoDB (Atlas in production; local/in-memory for development)
MONGODB_URI=mongodb://127.0.0.1:27017/clinicos

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
COOKIE_SECURE=false

# Redis (optional — core operations work without it)
REDIS_URL=redis://127.0.0.1:6379

# Cloudinary (secure media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# Account lockout
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ---- Web (apps/web) ----
VITE_API_URL=http://localhost:4000

# ---- Patient Web (apps/patient-web) ----
VITE_API_URL=http://localhost:4000
